<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF5E6"
    android:padding="30dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/myToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FDF5E6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:titleTextColor="?attr/colorPrimary" />

    <TextView
        android:id="@+id/tvLogoInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Organizador de festas"
        android:textColor="#555555"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/myToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvVersao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Versão: 3.0.0"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvLogoInfo"
        app:layout_constraintStart_toStartOf="@id/tvLogoInfo" />

    <TextView
        android:id="@+id/tvSistema"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de administração de festas"
        android:textColor="#333333"
        android:textSize="18sp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvVersao"
        app:layout_constraintStart_toStartOf="@id/tvVersao" />

    <TextView
        android:id="@+id/tvDevLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Desenvolvedor:"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSistema"
        app:layout_constraintStart_toStartOf="@id/tvSistema" />

    <TextView
        android:id="@+id/tvNommeDev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ana Sofia de Oliveira Silva Lima"
        android:textColor="#0000FF"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/tvDevLabel"
        app:layout_constraintStart_toEndOf="@id/tvDevLabel"
        android:layout_marginStart="4dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>